{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$defs": {
    "profileEnum": {
      "type": "string",
      "enum": [
        "",
        "balanced",
        "max-performance",
        "max-durability",
        "max-cost-savings",
        "dev"
      ]
    }
  },
  "properties": {
    "lakehouseConfig": {
      "type": "object",
      "properties": {
        "profile": {
          "$ref": "#/$defs/profileEnum"
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucket": {
              "type": "string"
            },
            "region": {
              "type": "string",
              "minLength": 1
            },
            "read_ahead_max_bytes": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Adaptive read-ahead window ceiling in bytes; doubles from read_ahead_bytes on sequential scans, resets on random seeks (0 = default 8MB)"
            },
            "read_ahead_waste_threshold": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "Waste-feedback threshold for the adaptive read-ahead window: an evicted window with more than this fraction of its bytes never read halves the next window toward read_ahead_bytes; >= 1 disables (0 = default 0.5)"
            },
            "read_buffer_size": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Parquet page read buffer for ranged S3 opens in bytes (0 = default 1MB)"
            },
            "parquet_read_mode": {
              "type": "string",
              "enum": [
                "",
                "async",
                "sync"
              ],
              "default": "async",
              "description": "Parquet page read mode on ranged S3 opens: async (per-column read-ahead goroutine) or sync (rollback switch)"
            },
            "projected_fetch_mode": {
              "type": "string",
              "enum": [
                "",
                "planned",
                "window"
              ],
              "default": "planned",
              "description": "Read strategy for column-projected parquet reads: planned (plan-then-fetch exact coalesced column-chunk ranges, no speculative window) or window (adaptive read-ahead window — full rollback switch)"
            },
            "projected_fetch_max_bytes": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Per-file byte cap for the plan-then-fetch projected read; plans above the cap fall back to the window path (0 = default 16MB)"
            }
          }
        },
        "tenant": {
          "type": "object",
          "properties": {
            "orgid_header": {
              "type": "string"
            },
            "metrics_format": {
              "type": "string",
              "enum": [
                "id",
                "name",
                "both"
              ]
            },
            "auto_register": {
              "type": "boolean"
            },
            "alias_sync_interval": {
              "type": "string"
            },
            "aliases": {
              "type": "object"
            }
          }
        },
        "compaction": {
          "type": "object",
          "description": "Background Parquet compaction (election-free, HRW-owned).",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "interval": {
              "type": "string",
              "description": "Compaction scan interval (Go duration)"
            },
            "max_concurrent": {
              "type": "integer",
              "minimum": 1
            },
            "min_files_l0": {
              "type": "integer",
              "minimum": 2
            },
            "min_files_l1": {
              "type": "integer",
              "minimum": 2
            },
            "min_age": {
              "type": "string",
              "description": "Minimum file age before compaction eligibility (Go duration)"
            },
            "daily_rollup_age": {
              "type": "string",
              "description": "Minimum partition age for daily rollup compaction (Go duration)"
            },
            "compression_level_by_output_level": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "description": "Progressive zstd schedule: slot N = compression level for output files at compaction level N (saturates at last slot; empty = insert.compression_level)"
            },
            "row_group_size_by_output_level": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "description": "Parquet row-group size schedule: slot N = max rows per row group for output files at compaction level N (saturates at last slot; empty = insert.row_group_size)"
            }
          },
          "additionalProperties": false
        },
        "pmeta": {
          "type": "object",
          "description": "pmeta unified partition-metadata layer (catalog + file-meta + bloom facets). Default on; disabling is a degraded mode.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "cardinality_threshold": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Distinct-values cap per field before high-card (0 = default 50000)"
            },
            "always_sketch_fields": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Id columns to HLL-sketch instead of enumerate (trace_id/span_id supported)"
            },
            "refuse_sketch_enumeration": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "logs": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "profile": {
          "$ref": "#/$defs/profileEnum"
        },
        "config": {
          "type": "object"
        },
        "select": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "profile": {
              "$ref": "#/$defs/profileEnum"
            },
            "replicaCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "insert": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "profile": {
              "$ref": "#/$defs/profileEnum"
            },
            "replicaCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "traces": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "profile": {
          "$ref": "#/$defs/profileEnum"
        },
        "config": {
          "type": "object"
        },
        "select": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "profile": {
              "$ref": "#/$defs/profileEnum"
            },
            "replicaCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "insert": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "profile": {
              "$ref": "#/$defs/profileEnum"
            },
            "replicaCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "vmauth": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}