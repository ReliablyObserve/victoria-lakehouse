{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "lakehouseConfig": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["logs", "traces"]
        },
        "role": {
          "type": "string",
          "enum": ["all", "insert", "select"]
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucket": {
              "type": "string"
            },
            "region": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "select": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "insertComponent": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "vmauth": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
