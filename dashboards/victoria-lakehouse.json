      "targets": [{ "expr": "sum by (reason) (rate(lakehouse_parquet_row_groups_skipped_total{instance=~\"$instance\"}[5m]))", "legendFormat": "{{reason}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 42,
