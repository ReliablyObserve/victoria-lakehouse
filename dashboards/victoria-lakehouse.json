      "title": "S3 Throughput",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(lakehouse_s3_bytes_read_total{instance=~\"$instance\"}[5m])", "legendFormat": "read" },
        { "expr": "rate(lakehouse_insert_bytes_uploaded_total{instance=~\"$instance\"}[5m])", "legendFormat": "write" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 31,
      "title": "Cache Hits by Tier",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (tier) (rate(lakehouse_cache_hits_total{instance=~\"$instance\"}[5m]))", "legendFormat": "{{tier}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 32,
      "title": "Cache Misses by Tier",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (tier) (rate(lakehouse_cache_misses_total{instance=~\"$instance\"}[5m]))", "legendFormat": "{{tier}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
