      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(lakehouse_insert_flush_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(lakehouse_insert_flush_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 60,
      "title": "Manifest & Discovery",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "id": 61,
