      "type": "timeseries",
      "targets": [
        { "expr": "lakehouse_cache_memory_bytes{instance=~\"$instance\"}", "legendFormat": "L1 memory" },
        { "expr": "lakehouse_cache_disk_bytes{instance=~\"$instance\"}", "legendFormat": "L2 disk" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Parquet Engine",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 41,
      "title": "Row Groups Skipped",
