      "id": 63,
      "title": "Singleflight Dedup",
      "type": "timeseries",
      "targets": [{ "expr": "rate(lakehouse_cache_singleflight_dedup_total{instance=~\"$instance\"}[5m])", "legendFormat": "dedup/s" }]
