      "targets": [
        { "expr": "rate(lakehouse_parquet_row_groups_scanned_total{instance=~\"$instance\"}[5m])", "legendFormat": "scanned" },
        { "expr": "sum(rate(lakehouse_parquet_row_groups_skipped_total{instance=~\"$instance\"}[5m]))", "legendFormat": "skipped" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
