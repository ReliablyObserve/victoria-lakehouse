{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "external link",
      "tags": ["victoria-lakehouse"],
      "title": "Single Instance",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Fleet Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Instances Ready",
      "type": "stat",
      "targets": [{ "expr": "count(lakehouse_ready{job=~\"$job\"} == 1)", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Instances",
      "type": "stat",
      "targets": [{ "expr": "count(lakehouse_info{job=~\"$job\"})", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Fleet Manifest Files",
      "type": "stat",
      "targets": [{ "expr": "sum(lakehouse_manifest_files{job=~\"$job\"})", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Fleet Manifest Bytes",
      "type": "stat",
      "targets": [{ "expr": "sum(lakehouse_manifest_bytes{job=~\"$job\"})", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Fleet Active Queries",
      "type": "stat",
      "targets": [{ "expr": "sum(lakehouse_concurrent_select_current{job=~\"$job\"})", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Fleet Insert Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(lakehouse_insert_rows_total{job=~\"$job\"}[5m]))", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Peer Ring Members",
      "type": "stat",
      "targets": [{ "expr": "max(lakehouse_peer_ring_members{job=~\"$job\"})", "legendFormat": "" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Fleet RED (Rate / Errors / Duration)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 11,
      "title": "Fleet Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (path) (rate(lakehouse_http_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "{{path}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 12,
      "title": "Fleet Error Rate (%)",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_http_errors_total{job=~\"$job\"}[5m])) / sum(rate(lakehouse_http_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "error %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 13,
      "title": "Fleet Query Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(lakehouse_query_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(lakehouse_query_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(lakehouse_query_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Peer Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 15 },
      "id": 21,
      "title": "Peer Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_peer_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "requests/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 15 },
      "id": 22,
      "title": "Peer Hit Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(lakehouse_peer_cache_hits_total{job=~\"$job\"}[5m]))", "legendFormat": "hits/s" },
        { "expr": "sum(rate(lakehouse_peer_requests_total{job=~\"$job\"}[5m])) - sum(rate(lakehouse_peer_cache_hits_total{job=~\"$job\"}[5m]))", "legendFormat": "misses/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 15 },
      "id": 23,
      "title": "Peer Bytes Transferred",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_peer_bytes_received_total{job=~\"$job\"}[5m]))", "legendFormat": "bytes/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 15 },
      "id": 24,
      "title": "Peer Error Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_peer_errors_total{job=~\"$job\"}[5m])) / (sum(rate(lakehouse_peer_requests_total{job=~\"$job\"}[5m])) + 1)", "legendFormat": "error %" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Fleet S3",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 31,
      "title": "Fleet S3 Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (op) (rate(lakehouse_s3_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "{{op}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 32,
      "title": "Fleet S3 Throttle Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_s3_throttle_total{job=~\"$job\"}[5m]))", "legendFormat": "throttle/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 33,
      "title": "Fleet S3 Throughput",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(lakehouse_s3_bytes_read_total{job=~\"$job\"}[5m]))", "legendFormat": "read" },
        { "expr": "sum(rate(lakehouse_insert_bytes_uploaded_total{job=~\"$job\"}[5m]))", "legendFormat": "write" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Fleet Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 41,
      "title": "Fleet Cache Hits by Tier",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (tier) (rate(lakehouse_cache_hits_total{job=~\"$job\"}[5m]))", "legendFormat": "{{tier}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 42,
      "title": "Fleet Cache Hit Ratio by Tier",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (tier) (rate(lakehouse_cache_hits_total{job=~\"$job\"}[5m])) / (sum by (tier) (rate(lakehouse_cache_hits_total{job=~\"$job\"}[5m])) + sum by (tier) (rate(lakehouse_cache_misses_total{job=~\"$job\"}[5m])))", "legendFormat": "{{tier}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 43,
      "title": "Fleet Cache Size (sum)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(lakehouse_cache_memory_bytes{job=~\"$job\"})", "legendFormat": "L1 memory total" },
        { "expr": "sum(lakehouse_cache_disk_bytes{job=~\"$job\"})", "legendFormat": "L2 disk total" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 50,
      "title": "Fleet Insert / Write Path",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 42 },
      "id": 51,
      "title": "Fleet Insert Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(lakehouse_insert_rows_total{job=~\"$job\"}[5m]))", "legendFormat": "rows/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 42 },
      "id": 52,
      "title": "Fleet Rows Buffered",
      "type": "timeseries",
      "targets": [{ "expr": "sum(lakehouse_insert_rows_buffered{job=~\"$job\"})", "legendFormat": "total buffered" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 42 },
      "id": 53,
      "title": "Fleet Flush Rate & Errors",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(lakehouse_insert_flush_total{job=~\"$job\"}[5m]))", "legendFormat": "flushes/s" },
        { "expr": "sum(rate(lakehouse_insert_flush_errors_total{job=~\"$job\"}[5m]))", "legendFormat": "errors/s" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 60,
      "title": "Per-Instance Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "id": 61,
      "title": "Request Rate by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (instance) (rate(lakehouse_http_requests_total{job=~\"$job\"}[5m]))", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 51 },
      "id": 62,
      "title": "Query p95 by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (instance, le) (rate(lakehouse_query_duration_seconds_bucket{job=~\"$job\"}[5m])))", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "id": 63,
      "title": "Insert Rate by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "rate(lakehouse_insert_rows_total{job=~\"$job\"}[5m])", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 59 },
      "id": 64,
      "title": "Cache Memory by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "lakehouse_cache_memory_bytes{job=~\"$job\"}", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 59 },
      "id": 65,
      "title": "Cache Disk by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "lakehouse_cache_disk_bytes{job=~\"$job\"}", "legendFormat": "{{instance}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 59 },
      "id": 66,
      "title": "Startup Phase by Instance",
      "type": "timeseries",
      "targets": [{ "expr": "lakehouse_startup_phase{job=~\"$job\"}", "legendFormat": "{{instance}}" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["victoria-lakehouse", "victoria-lakehouse-cluster"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(lakehouse_info, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "job",
        "query": { "query": "label_values(lakehouse_info, job)" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Victoria Lakehouse Cluster",
  "uid": "victoria-lakehouse-cluster",
  "version": 1
}
