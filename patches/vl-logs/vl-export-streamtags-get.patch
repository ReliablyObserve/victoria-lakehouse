@@ -35,6 +35,21 @@ type StreamTags struct {
 	tags []Field
 }
 
+// Get returns the value of the tag with the given name and whether it was found.
+// Added by patches/vl-logs/vl-export-streamtags-get.patch — used by the
+// lakehouse cold tier's insert path to lift stream-tag values (e.g. level)
+// onto row-level columns at write time without re-parsing the canonical
+// string. Linear scan because st.tags is typically small (≤ 10 stream
+// fields per the -stream-fields config); a map would amortize worse.
+func (st *StreamTags) Get(name string) (string, bool) {
+	for _, t := range st.tags {
+		if t.Name == name {
+			return t.Value, true
+		}
+	}
+	return "", false
+}
+
 // Reset resets st for reuse
 func (st *StreamTags) Reset() {
 	// Clear references to strings, which can belong to external buffers.
@@ -115,6 +130,19 @@ func (st *StreamTags) unmarshalStringInplace(s string) error {
 	return err
 }
 
+// UnmarshalString is an exported wrapper around the package-local
+// unmarshalStringInplace. Added by patches/vl-logs/vl-export-streamtags-unmarshal.patch
+// so the lakehouse cold tier's compactor can re-parse the
+// human-readable stream tag string stored in schema.LogRow.Stream
+// without resorting to a regex parser. Used to backfill row-level
+// SeverityText from the stream-label `level` tag on historical
+// parquet files written before the insert-time severity fallback
+// existed. As with unmarshalStringInplace, st points into s — the
+// caller must not mutate s while st is in use.
+func (st *StreamTags) UnmarshalString(s string) error {
+	return st.unmarshalStringInplace(s)
+}
