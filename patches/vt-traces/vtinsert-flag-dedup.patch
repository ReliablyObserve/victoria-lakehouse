diff --git a/app/vtinsert/insertutil/common_params.go b/app/vtinsert/insertutil/common_params.go
index c798218..6ece344 100644
--- a/app/vtinsert/insertutil/common_params.go
+++ b/app/vtinsert/insertutil/common_params.go
@@ -18,10 +18,19 @@ import (
 	"github.com/VictoriaMetrics/metrics"
 )
 
-var (
-	defaultMsgValue = flag.String("defaultMsgValue", "-",
+// defaultMsgValue is shared with VL's own -defaultMsgValue flag when both
+// vtinsert and vlinsert are linked into the same binary (lakehouse-traces).
+// flag.Lookup detects the prior registration from vlinsert/insertutil and
+// reuses its Value rather than panicking on the duplicate registration.
+// Added by patches/vt-traces/vtinsert-flag-dedup.patch.
+var defaultMsgValue = func() *string {
+	if existing := flag.Lookup("defaultMsgValue"); existing != nil {
+		s := existing.Value.String()
+		return &s
+	}
+	return flag.String("defaultMsgValue", "-",
 		"Default value for _msg field; see https://docs.victoriametrics.com/victorialogs/keyconcepts/#message-field")
-)
+}()
 
 // CommonParams contains common HTTP parameters used by log ingestion APIs.
 //
diff --git a/app/vtinsert/insertutil/flags.go b/app/vtinsert/insertutil/flags.go
index 547ac8f..960802d 100644
--- a/app/vtinsert/insertutil/flags.go
+++ b/app/vtinsert/insertutil/flags.go
@@ -2,10 +2,20 @@ package insertutil
 
 import (
 	"flag"
+	"strconv"
 )
 
-var (
-	// MaxFieldsPerLine is the maximum number of fields per line for /insert/* handlers
-	MaxFieldsPerLine = flag.Int("insert.maxFieldsPerLine", 1000, "The maximum number of log fields per line, which can be read by /insert/* handlers; "+
+// MaxFieldsPerLine is shared with VL's vlinsert/insertutil.MaxFieldsPerLine
+// when both packages are linked into the lakehouse-traces binary. The
+// flag.Lookup check detects VL's prior registration (vlinsert always
+// initializes before vtinsert per lakehouse-traces/main.go import order)
+// and reuses the existing Value rather than panicking on duplicate
+// registration. Added by patches/vt-traces/vtinsert-flag-dedup.patch.
+var MaxFieldsPerLine = func() *int {
+	if existing := flag.Lookup("insert.maxFieldsPerLine"); existing != nil {
+		v, _ := strconv.Atoi(existing.Value.String())
+		return &v
+	}
+	return flag.Int("insert.maxFieldsPerLine", 1000, "The maximum number of log fields per line, which can be read by /insert/* handlers; "+
 		"see https://docs.victoriametrics.com/victorialogs/faq/#how-many-fields-a-single-log-entry-may-contain")
-)
+}()
