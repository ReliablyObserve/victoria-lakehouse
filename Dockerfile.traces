# Builder runs on the native host arch (BUILDPLATFORM). Go cross-compiles to
# TARGETOS/TARGETARCH via env vars below. Running the builder natively avoids
# the QEMU `git clone` "cannot pread pack file: Bad address" failure on large
# repos (VictoriaLogs is ~70 MB packed) when buildx targets a foreign arch.
FROM --platform=$BUILDPLATFORM golang:1.26.4-alpine3.22 AS builder
RUN apk add --no-cache git
WORKDIR /app
ARG VERSION=dev
ARG VL_VERSION=v1.50.0
# VictoriaLogs at commit 77df0c04d532 (VictoriaTraces v0.9.2 compatible)
ARG VL_COMMIT=77df0c04d532
ARG VT_VERSION=v0.9.2
ARG TARGETOS
ARG TARGETARCH
# FIPS=1 enables Go 1.26+ native FIPS 140-3 mode. See Dockerfile.logs for the
# full activation matrix.
ARG FIPS=0
ENV GOWORK=off
ENV GOFIPS140=${FIPS:+v1.0.0}
COPY go.mod go.sum ./
COPY lakehouse-traces/go.mod lakehouse-traces/go.sum ./lakehouse-traces/
RUN mkdir -p deps lakehouse-traces/deps && \
    git clone --depth 1 --branch ${VL_VERSION} https://github.com/VictoriaMetrics/VictoriaLogs.git deps/VictoriaLogs && \
    git clone https://github.com/VictoriaMetrics/VictoriaLogs.git /tmp/vl-src && \
    cd /tmp/vl-src && git checkout ${VL_COMMIT} && \
    cp -r /tmp/vl-src /app/lakehouse-traces/deps/VictoriaLogs && \
    rm -rf /tmp/vl-src && \
    cd /app && \
    git clone --depth 1 --branch ${VT_VERSION} https://github.com/VictoriaMetrics/VictoriaTraces.git lakehouse-traces/deps/VictoriaTraces && \
    cd /app && go mod download && \
    cd /app/lakehouse-traces && go mod download
COPY patches/ /tmp/patches/
RUN cp /tmp/patches/vl-logs/external.go.src deps/VictoriaLogs/app/vlstorage/external.go && \
    cp /tmp/patches/vl-logs/external_query.go.src deps/VictoriaLogs/lib/logstorage/external_query.go && \
    cd deps/VictoriaLogs && git apply /tmp/patches/vl-logs/vlstorage-dispatch.patch && \
    git apply /tmp/patches/vl-logs/vl-export-severity.patch && \
    git apply /tmp/patches/vl-logs/vl-export-streamtags-get.patch
RUN cp /tmp/patches/vl-traces/external.go.src lakehouse-traces/deps/VictoriaLogs/app/vlstorage/external.go && \
    cp /tmp/patches/vl-traces/external_query.go.src lakehouse-traces/deps/VictoriaLogs/lib/logstorage/external_query.go && \
    cd lakehouse-traces/deps/VictoriaLogs && git apply /tmp/patches/vl-traces/vlstorage-dispatch.patch && \
    git apply /tmp/patches/vl-traces/vl-export-severity.patch && \
    git apply /tmp/patches/vl-traces/vl-export-streamtags-get.patch
RUN cp /tmp/patches/vt-traces/external.go.src lakehouse-traces/deps/VictoriaTraces/app/vtstorage/external.go && \
    cp /tmp/patches/vt-traces/flag_dedup.go.src lakehouse-traces/deps/VictoriaTraces/app/vtstorage/flag_dedup.go && \
    cd lakehouse-traces/deps/VictoriaTraces && git apply /tmp/patches/vt-traces/vtstorage-dispatch.patch && \
    git apply /tmp/patches/vt-traces/vtstorage-flag-dedup.patch && \
    git apply /tmp/patches/vt-traces/vtinsert-flag-dedup.patch && \
    git apply /tmp/patches/vt-traces/jaeger-tolerant-tags.patch && \
    git apply /tmp/patches/vt-traces/go-mod-replace.patch
COPY . .
RUN cp -r lakehouse-traces/deps/VictoriaLogs/app/vlselect/vmui/* internal/ui/vmui/
# The healthcheck binary (~3 MB) was folded into the main binary as
# `lakehouse-traces healthcheck` in PR #96. Saves ~10% of image size.
RUN cd lakehouse-traces && \
    CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} \
    go build -trimpath -ldflags="-s -w -X github.com/VictoriaMetrics/VictoriaMetrics/lib/buildinfo.Version=${VERSION}" -o /lakehouse-traces .
RUN mkdir -p /data/lakehouse/cache

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /lakehouse-traces /usr/local/bin/lakehouse-traces
COPY --from=builder --chown=65532:65532 /data/lakehouse /data/lakehouse
USER nonroot
EXPOSE 10428
ENTRYPOINT ["/usr/local/bin/lakehouse-traces"]
